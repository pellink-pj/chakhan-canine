{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "ui_kits/mungmate_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:NanumSquareRound))/i]",
        "message": "Font not provided by the design system. Available: NanumSquareRound."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|good|hope|caution|info|gold|neutral)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'good' | 'hope' | 'caution' | 'info' | 'gold' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|full|icon|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, full, icon, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gradient|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gradient' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|interactive|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, interactive, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|icon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, icon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|sub|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ChoiceCard> doesn't accept that prop. Declared props: icon, label, sub, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TraitCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|text|tone|style|key|ref|className|style|children)$/]",
        "message": "<TraitCard> doesn't accept that prop. Declared props: icon, title, text, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TraitCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:good|hope|caution)$/]",
        "message": "<TraitCard> tone must be one of 'good' | 'hope' | 'caution'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TraitMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|score|max|scaleWord|tone|style|key|ref|className|style|children)$/]",
        "message": "<TraitMeter> doesn't accept that prop. Declared props: label, score, max, scaleWord, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TraitMeter'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|good|hope|caution)$/]",
        "message": "<TraitMeter> tone must be one of 'brand' | 'good' | 'hope' | 'caution'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
